    <bpmn:sequenceFlow id="Flow_1evapmr" sourceRef="Task_ExaminePatient" targetRef="Task_VerifyInsurance" />
    <bpmn:sequenceFlow id="Flow_195ub0j" sourceRef="Gateway_InsuranceValid" targetRef="Task_CreateImagingOrder" />
    <bpmn:sequenceFlow id="Flow_0mjnk11" name="NO" sourceRef="Gateway_InsuranceValid" targetRef="Task_SendCancellation" />
    <bpmn:sequenceFlow id="Flow_11xr7s2" sourceRef="Task_RecordFinancialApproval" targetRef="Gateway_InsuranceValid" />
    <bpmn:sequenceFlow id="Flow_0kd2bz3" sourceRef="Task_UpdatePatientInfo" targetRef="Task_CreateVisit" />
    <bpmn:sequenceFlow id="Flow_0a43pt0" sourceRef="Task_RegisterPatient" targetRef="Task_UpdatePatientInfo" />
    <bpmn:sequenceFlow id="Flow_1nfyywj" sourceRef="Start_ReceivePatientData" targetRef="Task_RegisterPatient" />
    <bpmn:serviceTask id="Task_CreateVisit" name="Create Patient Visit">
      <bpmn:incoming>Flow_H3</bpmn:incoming>
      <bpmn:incoming>Flow_0kd2bz3</bpmn:incoming>
      <bpmn:outgoing>Flow_H4</bpmn:outgoing>
      <bpmn:outgoing>Flow_1tafe0s</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_ExaminePatient" name="Examine Patient">
      <bpmn:incoming>Flow_H4</bpmn:incoming>
      <bpmn:incoming>Flow_1tafe0s</bpmn:incoming>
