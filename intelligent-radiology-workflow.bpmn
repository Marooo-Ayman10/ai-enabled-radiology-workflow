    </bpmn:startEvent>
    <bpmn:sendTask id="Task_SendORM" name="Send HL7 ORM Order">
      <bpmn:incoming>Flow_H10</bpmn:incoming>
      <bpmn:incoming>Flow_0mu6k4k</bpmn:incoming>
