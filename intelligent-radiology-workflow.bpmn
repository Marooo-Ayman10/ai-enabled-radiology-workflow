      <bpmn:incoming>Flow_1ktqi4t</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:intermediateCatchEvent id="Event_ReceiveORU" name="Receive HL7 ORU Report">
      <bpmn:incoming>Flow_H11</bpmn:incoming>
      <bpmn:incoming>Flow_1tue6eg</bpmn:incoming>
      <bpmn:outgoing>Flow_H12</bpmn:outgoing>
      <bpmn:outgoing>Flow_196cw18</bpmn:outgoing>
