  <bpmn:process id="Process_Synapse" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Synapse">
      <bpmn:lane id="Lane_AI" name="AI Engine">
        <bpmn:flowNodeRef>Gateway_AIEnabled</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AnalyzeImages</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_GenerateAIFindings</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SendAIFindings</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_PACS" name="PACS Archive">
        <bpmn:flowNodeRef>Task_ReceiveDICOM</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ArchiveDICOM</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RetrieveImages</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SendImagesForReporting</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Modality" name="Modality Technician">
        <bpmn:flowNodeRef>Gateway_ImagesComplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_VerifyImageQuality</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PerformExam</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RetrieveMWL</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SendDICOM</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RepeatAcquisition</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_RIS" name="RIS">
        <bpmn:flowNodeRef>Task_GenerateAccession</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Start_ReceiveORM</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ScheduleExam</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PublishMWL</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SendAppointment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RescheduleExam</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SendORU</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_StoreStructuredReport</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_ReceiveApprovedReport</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_RISComplete</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:sequenceFlow id="Flow_S1" sourceRef="Start_ReceiveORM" targetRef="Task_GenerateAccession" />
    <bpmn:sequenceFlow id="Flow_S2" sourceRef="Task_GenerateAccession" targetRef="Task_ScheduleExam" />
    <bpmn:sequenceFlow id="Flow_S3" sourceRef="Task_ScheduleExam" targetRef="Task_PublishMWL" />
    <bpmn:sequenceFlow id="Flow_S4" sourceRef="Task_PublishMWL" targetRef="Task_SendAppointment" />
    <bpmn:sequenceFlow id="Flow_S5" name="Patient Attended" sourceRef="Task_SendAppointment" targetRef="Task_RetrieveMWL" />
    <bpmn:sequenceFlow id="Flow_S5_No" name="No Show" sourceRef="Task_SendAppointment" targetRef="Task_RescheduleExam" />
    <bpmn:sequenceFlow id="Flow_S6" sourceRef="Task_RetrieveMWL" targetRef="Task_PerformExam" />
    <bpmn:sequenceFlow id="Flow_S7" sourceRef="Task_PerformExam" targetRef="Task_VerifyImageQuality" />
    <bpmn:sequenceFlow id="Flow_S8" sourceRef="Task_VerifyImageQuality" targetRef="Gateway_ImagesComplete" />
    <bpmn:sequenceFlow id="Flow_S8_No" name="No" sourceRef="Gateway_ImagesComplete" targetRef="Task_RepeatAcquisition" />
    <bpmn:sequenceFlow id="Flow_S8_No_Loop" sourceRef="Task_RepeatAcquisition" targetRef="Task_VerifyImageQuality" />
