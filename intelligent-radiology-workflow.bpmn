    </bpmn:intermediateCatchEvent>
    <bpmn:sendTask id="Task_NotifyPatient" name="Notify Patient">
      <bpmn:incoming>Flow_H12</bpmn:incoming>
      <bpmn:incoming>Flow_196cw18</bpmn:incoming>
      <bpmn:outgoing>Flow_H13</bpmn:outgoing>
      <bpmn:outgoing>Flow_1ktqi4t</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:userTask id="Task_RecordFinancialApproval" name="Record Financial Approval">
      <bpmn:incoming>Flow_H6</bpmn:incoming>
      <bpmn:incoming>Flow_0th0y8o</bpmn:incoming>
      <bpmn:outgoing>Flow_H7</bpmn:outgoing>
      <bpmn:outgoing>Flow_11xr7s2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:dataStoreReference id="DataStoreReference_1d8vb33" name="Billing Database" />
    <bpmn:userTask id="Task_VerifyInsurance" name="Verify Insurance Eligibility">
      <bpmn:incoming>Flow_H5</bpmn:incoming>
      <bpmn:incoming>Flow_1evapmr</bpmn:incoming>
      <bpmn:outgoing>Flow_H6</bpmn:outgoing>
      <bpmn:outgoing>Flow_0th0y8o</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_InsuranceValid" name="Insurance Valid?">
