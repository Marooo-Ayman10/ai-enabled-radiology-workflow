    <bpmn:userTask id="Task_RegisterPatient" name="Register Patient">
      <bpmn:incoming>Flow_H1</bpmn:incoming>
      <bpmn:incoming>Flow_1nfyywj</bpmn:incoming>
      <bpmn:outgoing>Flow_H2</bpmn:outgoing>
      <bpmn:outgoing>Flow_0a43pt0</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:startEvent id="Start_ReceivePatientData" name="Receive Patient Data">
